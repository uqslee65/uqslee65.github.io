# Public API URL — points to the deployed Hono backend (Heroku or local)
# Used by src/lib/api/sim-client.ts via import.meta.env.PUBLIC_API_URL
PUBLIC_API_URL=https://your-heroku-app.herokuapp.com

# DeepSeek API key — BYOK only, entered in the LLMConfigPanel UI at runtime
# NEVER commit a real key. For local Playwright tests only:
# DEEPSEEK_API_KEY=sk-...
