---
import StandaloneLayout from '../layouts/StandaloneLayout.astro';
import BubbleSimulator from '../components/BubbleSimulator';
---

<StandaloneLayout title="DLM (2005) Bubble Simulator">
  <div class="sim-page">
    <div class="sim-header">
      <p class="sim-subtitle">
        Interactive replication of Dufwenberg, Lindqvist & Moore (AER 2005).
        SSW double auction with heterogeneous agents, experience-indexed belief updating, and round-4 novice replacement.
      </p>
    </div>

    <BubbleSimulator client:load />

    <div class="sim-footer">
      <details>
        <summary>About this simulation</summary>
        <div class="about-content">
          <p>
            Browser-based agent simulation of the SSW (Smith, Suchanek & Williams 1988)
            asset market as implemented by DLM (2005). Heterogeneous CRRA agents trade a
            <strong>single</strong> finite-lived asset across four consecutive rounds (no
            multi-asset portfolio); experienced traders are partially replaced by novices at
            the replacement round, optionally swapping to a different asset.
          </p>
          <p>
            <strong>Reproduces the four conclusions:</strong> (1) positive mispricing that
            decreases with experience; (2) a minority of experienced + majority of
            inexperienced traders do not generate large bubbles; (3) mispricing depends on the
            asset type; (4) experience does not transfer across uncorrelated assets.
          </p>
        </div>
      </details>
    </div>
  </div>
</StandaloneLayout>

<style>
  .sim-page {
    padding: 1.5rem 1rem;
  }
  .sim-header {
    margin-bottom: 1.5rem;
  }
  .sim-subtitle {
    font-size: 0.85rem;
    color: var(--text-dim);
    line-height: 1.5;
    max-width: 640px;
  }
  .sim-footer {
    margin-top: 2rem;
    border-top: 1px solid var(--border);
    padding-top: 1rem;
  }
  .sim-footer summary {
    font-size: 0.85rem;
    color: var(--text-dim);
    cursor: pointer;
  }
  .about-content {
    margin-top: 0.75rem;
    font-size: 0.8rem;
    color: var(--text-dim);
    line-height: 1.6;
    max-width: 640px;
  }
  .about-content p {
    margin-bottom: 0.5rem;
  }
</style>
