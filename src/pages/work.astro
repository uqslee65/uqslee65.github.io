---
import BaseLayout from '../layouts/BaseLayout.astro';
import GitHubActivity from '../components/GitHubActivity.tsx';
import LandingTabs from '../components/LandingTabs.tsx';
import { getCollection } from 'astro:content';
import { fetchCommitActivity, fetchRepoStats } from '../lib/github';
import type { TabItem } from '../components/LandingTabs.tsx';

const replications = (await getCollection('replications')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const commitData = await fetchCommitActivity('uqslee65', 'phd-finance-replications');
const repoStats = await fetchRepoStats('uqslee65', 'phd-finance-replications');

const totalCommits = commitData?.reduce((sum, w) => sum + w.total, 0) ?? 0;
const activeWeeks = commitData?.filter(w => w.total > 0).length ?? 0;

function toActivityLevels(data: typeof commitData): number[][] | null {
  if (!data) return null;
  const weeks = data.slice(-52);
  return weeks.map(w =>
    w.days.map(count => {
      if (count === 0) return 0;
      if (count <= 2) return 1;
      if (count <= 5) return 2;
      if (count <= 9) return 3;
      return 4;
    })
  );
}

const activityLevels = toActivityLevels(commitData);

const stats = [
  { label: 'Replications', value: replications.length },
  { label: 'Projects', value: 4 },
  { label: 'Commits (52w)', value: totalCommits },
  { label: 'Active Weeks', value: activeWeeks },
  { label: 'Stars', value: repoStats?.stars ?? 0 },
  { label: 'Forks', value: repoStats?.forks ?? 0 },
];

const projectItems: TabItem[] = [
  {
    title: 'DLM (2005) Virtual Trading Platform',
    subtitle: 'Experimental Economics · Market Microstructure',
    description: 'Browser-based replication of Dufwenberg, Lindqvist & Moore (AER 2005) asset market bubble experiment. Interactive dashboard with agent cards, order book, trade feed, and replay.',
    tags: ['experimental-economics', 'LLM', 'replication'],
    links: { site: '/simulator' },
  },
  {
    title: 'Collective Trades',
    subtitle: 'Fintech · Market Data',
    description: 'Real-time dashboard for insider trades, institutional holdings, and congressional disclosures. FastAPI backend with network-graph explorer and candlestick charts.',
    tags: ['fastapi', 'next.js', 'market-data'],
    links: { site: 'https://collective-trades-app-5371d48e9bf7.herokuapp.com' },
  },
  {
    title: 'Digital Transactions in Asia VII',
    subtitle: 'Conference Website',
    description: 'Conference website for the 7th Digital Transactions in Asia workshop (University of Peradeniya, Sri Lanka). Paper submission, registration, and schedule management.',
    tags: ['conference', 'next.js', 'digital-finance'],
    links: { site: 'https://www.icdtaaussl2026.com' },
  },
  {
    title: 'simple-finance',
    subtitle: 'Reusable Finance Research Library',
    description: 'Like tidyfinance but configurable. Abstracts common empirical finance methods — event studies, portfolio sorts, Fama-MacBeth, WRDS/FRED data pulls — into clean Python APIs.',
    tags: ['Python', 'Finance', 'Research'],
    links: { site: 'https://github.com/uqslee65/simple-finance' },
  },
];

const replicationItems: TabItem[] = replications.map(rep => ({
  title: rep.data.title,
  subtitle: rep.data.authors?.join(', ') + (rep.data.year ? ` (${rep.data.year})` : ''),
  description: rep.data.tldr ?? '',
  tags: rep.data.tags,
  status: rep.data.status,
  href: `/replications/${rep.id}`,
  links: {
    notebook: rep.data.notebook_url,
    slides: rep.data.slides_url,
    paper: rep.data.paper_url,
  },
}));

const researchItems: TabItem[] = [
  {
    title: 'ESG (Indigenous Outcomes) Modelling',
    subtitle: 'UQ Business School · 2025–2026',
    description: 'Data governance and textual modelling in ASX100 firm Indigenous engagement',
    tags: ['ESG', 'NLP', 'ASX100'],
    status: 'active',
    links: {},
  },
  {
    title: 'Multisource Attention-Conditioned Sentiment on Volatility',
    subtitle: 'AIBE · 2025–2026',
    description: 'Sentiment attention pressure on post-earnings volatility',
    tags: ['Sentiment', 'Volatility', 'Attention'],
    status: 'active',
    links: {},
  },
  {
    title: 'Cyber Risk Premium with PU Machine Learning',
    subtitle: 'UQ Business School · 2025–2026 · PhD Thesis',
    description: 'PU methods outperformed supervised benchmark; Fama-MacBeth regressions; H-L portfolio sorts',
    tags: ['Cyber Risk', 'PU Learning', 'Asset Pricing'],
    status: 'active',
    links: {},
  },
  {
    title: 'Portfolio Holdings Disclosure & Index-Hugging',
    subtitle: 'UQ Business School · 2025–',
    description: 'Portfolios shifted materially; derivative divestment; expect index-hugging',
    tags: ['Disclosure', 'Portfolio', 'Regulation'],
    status: 'active',
    links: {},
  },
  {
    title: 'Open Banking & Mortgage Rate Dispersion',
    subtitle: 'UQ Business School · 2024–2025',
    description: 'Loan aggregation products moved usage off-API; increased refinancing',
    tags: ['Open Banking', 'Fintech', 'Mortgages'],
    status: 'complete',
    links: {},
  },
  {
    title: 'Crisis As An Enabler for Rapid Growth',
    subtitle: 'UQ Business School · 2024',
    description: 'doc2vec ML models on cumulative abnormal returns',
    tags: ['Crisis', 'ML', 'Event Study'],
    status: 'complete',
    links: {},
  },
];
---

<BaseLayout title="Work — Joshua Lee">
  <header class="work-header">
    <h1 class="work-title">WORK</h1>
    <p class="work-subtitle">Projects, replications, and research</p>
  </header>

  <section class="dashboard-panel">
    <div class="dashboard-activity">
      <span class="activity-label">COMMIT ACTIVITY</span>
      <GitHubActivity client:load data={activityLevels} />
    </div>
    <div class="dashboard-stats">
      {stats.map(s => (
        <div class="stat-cell">
          <span class="stat-value">{s.value}</span>
          <span class="stat-label">{s.label}</span>
        </div>
      ))}
    </div>
  </section>

  <LandingTabs client:load projects={projectItems} replications={replicationItems} research={researchItems} />

  <footer class="work-footer">
    <p class="work-footer-text">
      University of Queensland · Business School · Finance
    </p>
  </footer>
</BaseLayout>

<style>
  .work-header {
    margin-bottom: 2rem;
  }
  .work-title {
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.16em;
    color: var(--text-faint);
    text-transform: uppercase;
    margin: 0;
  }
  .work-subtitle {
    font-size: 0.82rem;
    color: var(--text-dim);
    margin-top: 0.25rem;
  }

  .dashboard-panel {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    background: var(--border);
    gap: 1px;
    margin-bottom: 2.5rem;
  }
  .dashboard-activity {
    background: var(--bg-raised);
    padding: 1rem 1.25rem;
    overflow-x: auto;
  }
  .activity-label {
    display: block;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin-bottom: 0.6rem;
  }
  .dashboard-stats {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1px;
    background: var(--border);
  }
  .stat-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 0.5rem;
    background: var(--bg-raised);
  }
  .stat-value {
    font-size: 16px;
    font-weight: 300;
    color: var(--text);
    font-family: 'JetBrains Mono', monospace;
  }
  .stat-label {
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin-top: 0.25rem;
  }

  .work-footer {
    padding: 1.25rem 0;
    text-align: center;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    margin-top: 2rem;
  }
  .work-footer-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.2);
    text-transform: uppercase;
    margin: 0;
  }

  @media (max-width: 640px) {
    .dashboard-stats {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

<style is:global>
  .landing-tabs-section {
    max-width: none;
    padding: 0 0 2rem;
  }

  .tab-content {
    margin-top: 1.25rem;
  }

  .tab-cards {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .tab-card {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1.5rem;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    padding: 1.25rem 1.5rem;
    transition: border-color 0.2s;
  }

  .tab-card:hover {
    border-color: var(--border-mid);
  }

  .tab-card--link {
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .tab-card-body {
    min-width: 0;
  }

  .tab-card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .tab-card-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
    margin: 0;
  }

  .tab-card-subtitle {
    font-size: 0.78rem;
    color: var(--text-faint);
    margin-top: 0.15rem;
  }

  .tab-card-desc {
    font-size: 0.82rem;
    color: var(--text-dim);
    line-height: 1.55;
    margin-top: 0.4rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tab-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.5rem;
  }

  .tab-status {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 500;
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--border);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .tab-status--complete { color: var(--status-complete); }
  .tab-status--partial { color: var(--status-partial); }
  .tab-status--planned { color: var(--status-planned); }

  .tab-card-actions {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    justify-content: center;
    align-items: flex-end;
    flex-shrink: 0;
  }

  .tab-action-btn {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--border);
    color: var(--text-dim);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s, border-color 0.15s;
  }

  .tab-action-btn:hover {
    color: var(--text);
    border-color: var(--text-dim);
  }

  @media (max-width: 640px) {
    .tab-card {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
    .tab-card-actions {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: flex-start;
    }
  }
</style>
