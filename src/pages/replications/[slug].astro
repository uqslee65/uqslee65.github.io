---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const replications = await getCollection('replications');
  return replications.map(rep => ({ params: { slug: rep.id }, props: { rep } }));
}

const { rep } = Astro.props;
const { Content } = await render(rep);

// Authors: prefer structured array, fall back to legacy paper field
const authorsLine =
  rep.data.authors && rep.data.authors.length > 0
    ? rep.data.authors.join(', ')
    : (rep.data.paper ?? '');
---

<BaseLayout title={rep.data.title}>
  <div class="detail-wrapper">

    <!-- Back link -->
    <a href="/replications" class="back-link">← Back to Replications</a>

    <!-- Header block -->
    <header class="detail-header">
      <!-- Status + date row -->
      <div class="meta-row">
        <span class={`status-badge status-${rep.data.status}`}>
          {rep.data.status}
        </span>
        <span class="meta-date">{rep.data.date}</span>
      </div>

      <!-- Title — rendered exactly once -->
      <h1 class="detail-title">{rep.data.title}</h1>

      <!-- Authors — exactly once, never from rep.data.paper -->
      {authorsLine && (
        <p class="detail-authors">{authorsLine}</p>
      )}

      <!-- Venue + year -->
      {rep.data.venue && (
        <p class="detail-venue">
          {rep.data.venue}{rep.data.year ? ` (${rep.data.year})` : ''}
        </p>
      )}

      <!-- Tags -->
      {rep.data.tags.length > 0 && (
        <div class="tag-row">
          {rep.data.tags.map(tag => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}

      <!-- Action buttons -->
      <div class="action-row">
        {rep.data.slides_url ? (
          <a
            href={rep.data.slides_url}
            target="_blank"
            rel="noopener noreferrer"
            class="action-btn action-btn--active"
          >
            Conference Slides
          </a>
        ) : (
          <span class="action-btn action-btn--disabled" aria-disabled="true">
            Conference Slides
          </span>
        )}

        {rep.data.notebook_url ? (
          <a
            href={rep.data.notebook_url}
            target="_blank"
            rel="noopener noreferrer"
            class="action-btn action-btn--active"
          >
            Jupyter Notebook
          </a>
        ) : (
          <span class="action-btn action-btn--disabled" aria-disabled="true">
            Jupyter Notebook
          </span>
        )}

        {rep.data.paper_url ? (
          <a
            href={rep.data.paper_url}
            target="_blank"
            rel="noopener noreferrer"
            class="action-btn action-btn--active"
          >
            View Paper
          </a>
        ) : (
          <span class="action-btn action-btn--disabled" aria-disabled="true">
            View Paper
          </span>
        )}
      </div>
    </header>

    <!-- MDX body -->
    <div class="prose-body">
      <Content />
    </div>

  </div>
</BaseLayout>

<style>
  /* ---- Page container ---- */
  .detail-wrapper {
    max-width: 48rem; /* ~3xl */
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
  }

  /* ---- Back link ---- */
  .back-link {
    display: inline-block;
    font-size: 0.8rem;
    color: var(--fg-3);
    text-decoration: none;
    margin-bottom: 1.75rem;
    transition: color 0.15s;
  }
  .back-link:hover {
    color: var(--accent);
  }

  /* ---- Header ---- */
  .detail-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.75rem;
    border-bottom: 1px solid var(--border);
  }

  .meta-row {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-bottom: 0.75rem;
  }

  /* Status badges */
  .status-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    text-transform: lowercase;
    letter-spacing: 0.02em;
  }

  .status-complete {
    background: var(--success-bg);
    color: var(--success);
  }

  .status-partial {
    background: var(--warning-bg);
    color: var(--warning);
  }

  .status-planned {
    background: var(--stat-bg);
    color: var(--fg-3);
  }

  .meta-date {
    font-size: 0.78rem;
    color: var(--fg-3);
  }

  /* Title */
  .detail-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--fg);
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }

  /* Authors */
  .detail-authors {
    font-size: 0.9rem;
    color: var(--fg-2);
    margin-bottom: 0.25rem;
  }

  /* Venue */
  .detail-venue {
    font-size: 0.82rem;
    color: var(--fg-3);
    font-style: italic;
    margin-bottom: 0.75rem;
  }

  /* Tags */
  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 0.75rem;
    margin-bottom: 1rem;
  }

  /* Action buttons */
  .action-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    margin-top: 1rem;
  }

  .action-btn {
    display: inline-flex;
    align-items: center;
    font-size: 0.825rem;
    font-weight: 500;
    padding: 0.45rem 1rem;
    border-radius: 6px;
    border: 1px solid var(--border);
    text-decoration: none;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s, box-shadow 0.15s;
    user-select: none;
  }

  .action-btn--active {
    background: var(--accent-light);
    color: var(--accent);
    border-color: var(--accent);
  }

  .action-btn--active:hover {
    background: var(--accent);
    color: #fff;
    box-shadow: 0 2px 8px rgba(37, 99, 235, 0.25);
  }

  .action-btn--disabled {
    background: var(--stat-bg);
    color: var(--fg-3);
    cursor: default;
    opacity: 0.55;
  }

  /* ---- Prose body ---- */
  .prose-body {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--fg);
  }

  .prose-body :global(h2) {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--fg);
    margin-top: 2rem;
    margin-bottom: 0.6rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--border);
  }

  .prose-body :global(h3) {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--fg);
    margin-top: 1.5rem;
    margin-bottom: 0.4rem;
  }

  .prose-body :global(h4) {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--fg-2);
    margin-top: 1.25rem;
    margin-bottom: 0.3rem;
  }

  .prose-body :global(p) {
    margin-bottom: 1rem;
    color: var(--fg);
  }

  .prose-body :global(ul),
  .prose-body :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .prose-body :global(li) {
    margin-bottom: 0.3rem;
    color: var(--fg);
  }

  .prose-body :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose-body :global(a:hover) {
    color: var(--accent-hover);
  }

  .prose-body :global(strong) {
    font-weight: 600;
    color: var(--fg);
  }

  .prose-body :global(em) {
    color: var(--fg-2);
  }

  .prose-body :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
    margin: 1.25rem 0;
    color: var(--fg-2);
    font-style: italic;
  }

  .prose-body :global(pre) {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    overflow-x: auto;
    font-size: 0.82rem;
    line-height: 1.55;
    margin-bottom: 1.25rem;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }

  .prose-body :global(code) {
    font-size: 0.82rem;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.1em 0.35em;
  }

  /* Don't double-wrap code inside pre */
  .prose-body :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    border-radius: 0;
  }

  .prose-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
    margin-bottom: 1.25rem;
  }

  .prose-body :global(th) {
    text-align: left;
    font-weight: 600;
    color: var(--fg);
    padding: 0.5rem 0.75rem;
    border-bottom: 2px solid var(--border);
  }

  .prose-body :global(td) {
    padding: 0.45rem 0.75rem;
    border-bottom: 1px solid var(--border);
    color: var(--fg);
  }

  .prose-body :global(tr:last-child td) {
    border-bottom: none;
  }

  .prose-body :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }

  .prose-body :global(img) {
    max-width: 100%;
    border-radius: var(--radius);
    margin: 1rem 0;
  }

  /* ---- Responsive ---- */
  @media (max-width: 640px) {
    .detail-wrapper {
      padding: 1.5rem 1rem 3rem;
    }

    .detail-title {
      font-size: 1.3rem;
    }

    .action-row {
      flex-direction: column;
    }

    .action-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
