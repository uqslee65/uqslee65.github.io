---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RepoStats from '../../components/RepoStats.astro';

const replications = (await getCollection('replications')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

function authorsLine(rep: (typeof replications)[number]): string {
  if (rep.data.authors && rep.data.authors.length > 0) {
    return rep.data.authors.join(', ');
  }
  // Legacy fallback: strip leading title from paper citation
  return rep.data.paper ?? '';
}
---

<BaseLayout title="Replications">
  <div class="page-wrapper">
    <!-- Header -->
    <header class="page-header">
      <h1 class="page-title">Replications</h1>
      <p class="page-subtitle">
        Reproducible replication packages for published finance research. Each study includes
        regression tables, gate-checked tolerance bands, and documented divergences.
      </p>
      <div class="repo-stats-row">
        <RepoStats owner="uqslee65" repo="phd-finance-replications" />
      </div>
    </header>

    <!-- Card list -->
    {replications.length === 0 ? (
      <p class="empty-state">No replications yet.</p>
    ) : (
      <ul class="card-list">
        {replications.map(rep => (
          <li>
            <a href={`/replications/${rep.id}`} class="rep-card">
              <!-- Top row: status badge + date -->
              <div class="card-meta-row">
                <span class={`status-badge status-${rep.data.status}`}>
                  {rep.data.status}
                </span>
                <span class="card-date">{rep.data.date}</span>
              </div>

              <!-- Title -->
              <h2 class="card-title">{rep.data.title}</h2>

              <!-- Authors -->
              {authorsLine(rep) && (
                <p class="card-authors">{authorsLine(rep)}</p>
              )}

              <!-- Venue + year -->
              {rep.data.venue && (
                <p class="card-venue">
                  {rep.data.venue}{rep.data.year ? ` (${rep.data.year})` : ''}
                </p>
              )}

              <!-- TLDR -->
              {rep.data.tldr && (
                <p class="card-tldr">{rep.data.tldr}</p>
              )}

              <!-- Tags -->
              {rep.data.tags.length > 0 && (
                <div class="tag-row">
                  {rep.data.tags.map(tag => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              )}

              <!-- Action buttons -->
              <div class="action-row">
                {rep.data.slides_url ? (
                  <span class="action-btn action-btn--active" onclick={`event.preventDefault(); window.open('${rep.data.slides_url}','_blank')`}>
                    Slides
                  </span>
                ) : (
                  <span class="action-btn action-btn--disabled" aria-disabled="true">Slides</span>
                )}
                {rep.data.notebook_url ? (
                  <span class="action-btn action-btn--active" onclick={`event.preventDefault(); window.open('${rep.data.notebook_url}','_blank')`}>
                    Notebook
                  </span>
                ) : (
                  <span class="action-btn action-btn--disabled" aria-disabled="true">Notebook</span>
                )}
                {rep.data.paper_url ? (
                  <span class="action-btn action-btn--active" onclick={`event.preventDefault(); window.open('${rep.data.paper_url}','_blank')`}>
                    Paper
                  </span>
                ) : (
                  <span class="action-btn action-btn--disabled" aria-disabled="true">Paper</span>
                )}
              </div>
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</BaseLayout>

<style>
  .page-wrapper {
    max-width: 56rem; /* ~4xl */
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }

  /* Header */
  .page-header {
    margin-bottom: 2.5rem;
  }

  .page-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--fg);
    margin-bottom: 0.5rem;
  }

  .page-subtitle {
    font-size: 0.9rem;
    color: var(--fg-2);
    line-height: 1.6;
    max-width: 42rem;
    margin-bottom: 1.25rem;
  }

  .repo-stats-row {
    margin-top: 0.75rem;
  }

  /* Card list */
  .card-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .empty-state {
    font-size: 0.875rem;
    color: var(--fg-3);
  }

  /* Individual card */
  .rep-card {
    display: block;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    box-shadow: var(--shadow);
    text-decoration: none;
    color: var(--fg);
    transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
  }

  .rep-card:hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-2px);
    border-color: var(--accent);
    color: var(--fg);
  }

  /* Meta row */
  .card-meta-row {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-bottom: 0.5rem;
  }

  .card-date {
    font-size: 0.75rem;
    color: var(--fg-3);
  }

  /* Status badges */
  .status-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.15rem 0.55rem;
    border-radius: 9999px;
    text-transform: lowercase;
    letter-spacing: 0.02em;
  }

  .status-complete {
    background: var(--success-bg);
    color: var(--success);
  }

  .status-partial {
    background: var(--warning-bg);
    color: var(--warning);
  }

  .status-planned {
    background: var(--stat-bg);
    color: var(--fg-3);
  }

  /* Card body */
  .card-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--fg);
    margin-bottom: 0.25rem;
    line-height: 1.4;
  }

  .rep-card:hover .card-title {
    color: var(--accent);
  }

  .card-authors {
    font-size: 0.82rem;
    color: var(--fg-2);
    margin-bottom: 0.2rem;
  }

  .card-venue {
    font-size: 0.78rem;
    color: var(--fg-3);
    font-style: italic;
    margin-bottom: 0.4rem;
  }

  .card-tldr {
    font-size: 0.82rem;
    color: var(--fg-2);
    line-height: 1.55;
    margin-top: 0.4rem;
    margin-bottom: 0.5rem;
    /* Clamp to 2 lines */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Tags */
  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 0.625rem;
    margin-bottom: 0.75rem;
  }

  /* Action buttons */
  .action-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.625rem;
  }

  .action-btn {
    font-size: 0.72rem;
    font-weight: 500;
    padding: 0.25rem 0.7rem;
    border-radius: 6px;
    border: 1px solid var(--border);
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    user-select: none;
  }

  .action-btn--active {
    background: var(--accent-light);
    color: var(--accent);
    border-color: var(--accent);
  }

  .action-btn--active:hover {
    background: var(--accent);
    color: #fff;
  }

  .action-btn--disabled {
    background: var(--stat-bg);
    color: var(--fg-3);
    cursor: default;
    opacity: 0.6;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .page-wrapper {
      padding: 2rem 1rem;
    }

    .rep-card {
      padding: 1rem 1.125rem;
    }

    .action-row {
      flex-direction: row;
    }
  }
</style>
