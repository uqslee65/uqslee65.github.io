---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import StatsBar from '../components/StatsBar.tsx';
import ProjectCard from '../components/ProjectCard.astro';
import QuickLinks from '../components/QuickLinks.astro';
---

<BaseLayout title="Josh — PhD Finance Researcher">
  <Hero
    name="Josh"
    title="PhD Finance Researcher"
    tagline="Experimental Economics, Market Microstructure, LLM Agents"
  />

  <StatsBar client:visible />

  <div class="dashboard-grid">
    <ProjectCard
      name="DLM (2005) Replication"
      description="Browser-based replication of the Dufwenberg, Lindqvist & Moore asset market bubble experiment with AI agent extensions. Three-plan factorial with interactive dashboard."
      tags={['experimental-economics', 'LLM', 'market-microstructure']}
      featured={true}
    />

    <div class="card placeholder-card">
      <h3 class="placeholder-heading">Latest Research</h3>
      <p class="placeholder-text">Research notes and project writeups coming soon.</p>
      <a href="/research" class="placeholder-link">View all projects &rarr;</a>
    </div>

    <QuickLinks />
  </div>
</BaseLayout>

<style>
  .dashboard-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 2rem;
  }
  @media (max-width: 768px) {
    .dashboard-grid {
      grid-template-columns: 1fr;
    }
  }
  .placeholder-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .placeholder-heading {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--fg-2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .placeholder-text {
    font-size: 0.875rem;
    color: var(--fg-3);
  }
  .placeholder-link {
    margin-top: auto;
    font-size: 0.85rem;
    font-weight: 600;
  }
</style>
