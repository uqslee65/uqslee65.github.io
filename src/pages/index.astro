---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout title="Josh — PhD Finance Researcher">
  <Hero
    name="Joshua Lee"
    title="PhD Finance Student"
    tagline="Digital Finance · Data Assets & Markets · Empirical Asset Pricing"
  />

  <section class="landing-grid">
    <a href="/about" class="landing-card">
      <span class="card-icon">CV</span>
      <h3>About</h3>
      <p>Education, experience, awards, and skills.</p>
    </a>
    <a href="/research" class="landing-card">
      <span class="card-icon">R</span>
      <h3>Research</h3>
      <p>Working papers and ongoing projects.</p>
    </a>
    <a href="/replications" class="landing-card">
      <span class="card-icon">Re</span>
      <h3>Replications</h3>
      <p>Reproducible replication packages for published papers.</p>
    </a>
    <a href="/simulator" class="landing-card">
      <span class="card-icon">Sim</span>
      <h3>Simulator</h3>
      <p>Interactive DLM (2005) bubble experiment with LLM agents.</p>
    </a>
    <a href="/blog" class="landing-card">
      <span class="card-icon">B</span>
      <h3>Blog</h3>
      <p>Notes on finance, experiments, and building research tools.</p>
    </a>
  </section>
</BaseLayout>

<style>
  .landing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }
  .landing-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    text-decoration: none;
    transition: box-shadow 0.2s, transform 0.2s;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .landing-card:hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-2px);
  }
  .card-icon {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 6px;
    background: var(--accent);
    color: white;
    font-size: 0.75rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .landing-card h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--fg);
    margin: 0;
  }
  .landing-card p {
    font-size: 0.8rem;
    color: var(--fg-2);
    margin: 0;
    line-height: 1.4;
  }
</style>
