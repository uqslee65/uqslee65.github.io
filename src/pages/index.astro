---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { fetchCommitActivity } from '../lib/github';

const commitData = await fetchCommitActivity('uqslee65', 'phd-finance-replications');

function toActivityLevels(data: typeof commitData): number[][] | null {
  if (!data) return null;
  const weeks = data.slice(-52);
  return weeks.map(w =>
    w.days.map(count => {
      if (count === 0) return 0;
      if (count <= 2) return 1;
      if (count <= 5) return 2;
      if (count <= 9) return 3;
      return 4;
    })
  );
}

const activityLevels = toActivityLevels(commitData);
---

<BaseLayout title="Joshua Lee — PhD Finance" fullBleed={true}>
  <Hero activityData={activityLevels} />
</BaseLayout>
