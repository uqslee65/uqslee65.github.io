---
import BaseLayout from '../layouts/BaseLayout.astro';
import TabBar from '../components/TabBar.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const sortedProjects = projects.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Library — Monius">
  <h1 class="page-heading">Library</h1>

  <TabBar tabs={['Projects', 'Slides', 'CV', 'Papers']} />

  <div data-tab-content="Projects" class="tab-panel">
    <div class="project-grid">
      {sortedProjects.map(p => (
        <ProjectCard
          name={p.data.name}
          description={p.data.description}
          url={p.data.url}
          repo={p.data.repo}
          tags={p.data.tags}
          stars={p.data.stars}
          featured={p.data.featured}
        />
      ))}
    </div>
  </div>

  <div data-tab-content="Slides" class="tab-panel" style="display:none">
    <div class="content-section">
      <div class="card">
        <h3 class="section-title">AI-Agent Bubble Experiment</h3>
        <p class="section-desc">22-slide deck covering the DLM (2005) replication methodology, Plan I/II/III factorial design, and results.</p>
        <a href="https://assets.m0nius.com" target="_blank" rel="noopener" class="section-link">View Slides &rarr;</a>
      </div>
    </div>
  </div>

  <div data-tab-content="CV" class="tab-panel" style="display:none">
    <div class="content-section">
      <div class="card cv-card">
        <p class="cv-text">Download or view the latest version of my curriculum vitae.</p>
        <a href="/cv.pdf" class="cv-download">Download CV (PDF)</a>
      </div>
    </div>
  </div>

  <div data-tab-content="Papers" class="tab-panel" style="display:none">
    <div class="content-section">
      <div class="card">
        <h3 class="section-title">Working Papers</h3>
        <div class="paper-item">
          <p class="paper-title">Replicating Asset Market Bubbles with LLM Agents</p>
          <p class="paper-meta">Work in progress — Experimental Economics, Market Microstructure</p>
          <div class="paper-links">
            <a href="https://assets.m0nius.com" target="_blank" rel="noopener">Live Demo</a>
            <a href="https://github.com/Mon-ius/bubble" target="_blank" rel="noopener">Code</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .page-heading {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--fg);
    margin-bottom: 1.5rem;
    padding-top: 1rem;
  }
  .tab-panel {
    padding-top: 1.5rem;
  }
  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 640px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }
  .content-section {
    max-width: 40rem;
  }
  .section-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--fg);
    margin-bottom: 0.5rem;
  }
  .section-desc {
    font-size: 0.875rem;
    color: var(--fg-2);
    line-height: 1.5;
    margin-bottom: 0.75rem;
  }
  .section-link {
    font-size: 0.85rem;
    font-weight: 600;
  }
  .cv-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }
  .cv-text {
    font-size: 0.9rem;
    color: var(--fg-2);
  }
  .cv-download {
    display: inline-block;
    padding: 0.6rem 1.25rem;
    background: var(--accent);
    color: white;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    transition: background 0.15s;
  }
  .cv-download:hover {
    background: var(--accent-hover);
    color: white;
  }
  .paper-item {
    margin-top: 0.75rem;
  }
  .paper-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--fg);
  }
  .paper-meta {
    font-size: 0.8rem;
    color: var(--fg-3);
    margin-top: 0.25rem;
  }
  .paper-links {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
    font-size: 0.85rem;
    font-weight: 500;
  }
</style>
