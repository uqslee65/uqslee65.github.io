---
import BaseLayout from '../layouts/BaseLayout.astro';
import TabBar from '../components/TabBar.astro';
import ProjectCard from '../components/ProjectCard.astro';
---

<BaseLayout title="Research — Josh">
  <h1 class="page-heading">Research &amp; Projects</h1>

  <TabBar tabs={['Projects', 'Slides']} />

  <div data-tab-content="Projects" class="tab-panel">
    <div class="project-grid">
      <ProjectCard
        name="DLM (2005) Replication — Virtual Trading Platform"
        description="Browser-based replication of Dufwenberg, Lindqvist & Moore (AER 2005) asset market bubble experiment. Three-plan factorial: algorithmic belief update, LLM + utility forms, LLM + risk label. Interactive dashboard with 12 chart figures, agent cards, order book, trade feed, and replay."
        tags={['experimental-economics', 'market-microstructure', 'LLM', 'replication']}
        featured={true}
      />
      <ProjectCard
        name="Deception Game Experiment"
        description="Experimental economics replication studying deception and strategic communication in games."
        tags={['experimental-economics', 'game-theory']}
      />
      <ProjectCard
        name="Trading Simulator"
        description="Interactive trading simulation platform for market microstructure research."
        tags={['market-microstructure', 'simulation']}
      />
      <ProjectCard
        name="LLM Agent Markets"
        description="LLM-powered autonomous agents participating in experimental asset markets."
        tags={['LLM', 'autonomous-agents', 'finance']}
      />
    </div>
  </div>

  <div data-tab-content="Slides" class="tab-panel" style="display:none">
    <div class="slides-section">
      <div class="card slide-card">
        <h3 class="slide-title">DLM Replication — Methodology &amp; Results</h3>
        <p class="slide-desc">22-slide deck covering the DLM (2005) replication methodology, Plan I/II/III factorial design, and results.</p>
        <div class="slide-placeholder">
          <div class="slide-mock">
            <div class="slide-mock-header"></div>
            <div class="slide-mock-body">
              <div class="slide-mock-line w75"></div>
              <div class="slide-mock-line w50"></div>
              <div class="slide-mock-line w90"></div>
              <div class="slide-mock-line w60"></div>
            </div>
            <div class="slide-mock-footer"></div>
          </div>
          <p class="slide-note">Slide deck scaffold — replace with your presentation</p>
        </div>
      </div>

      <div class="card slide-card">
        <h3 class="slide-title">Research Presentation Template</h3>
        <p class="slide-desc">Blank scaffold for academic presentations. Add your slides as PDF or embed from Google Slides / Slidev.</p>
        <div class="slide-placeholder">
          <div class="slide-mock">
            <div class="slide-mock-header"></div>
            <div class="slide-mock-body">
              <div class="slide-mock-line w50"></div>
              <div class="slide-mock-line w75"></div>
            </div>
            <div class="slide-mock-footer"></div>
          </div>
          <p class="slide-note">Add your slide embed URL or PDF here</p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .page-heading {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--fg);
    margin-bottom: 1.5rem;
    padding-top: 1rem;
  }
  .tab-panel {
    padding-top: 1.5rem;
  }
  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 640px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }
  .slides-section {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 640px) {
    .slides-section {
      grid-template-columns: 1fr;
    }
  }
  .slide-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .slide-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--fg);
  }
  .slide-desc {
    font-size: 0.85rem;
    color: var(--fg-2);
    line-height: 1.5;
  }
  .slide-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    background: var(--stat-bg);
    border-radius: 8px;
  }
  .slide-mock {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 6px;
    display: flex;
    flex-direction: column;
    padding: 0.75rem;
    gap: 0.5rem;
  }
  .slide-mock-header {
    height: 8px;
    width: 40%;
    background: var(--accent);
    border-radius: 3px;
    opacity: 0.5;
  }
  .slide-mock-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    justify-content: center;
  }
  .slide-mock-line {
    height: 5px;
    background: var(--border);
    border-radius: 2px;
  }
  .w50 { width: 50%; }
  .w60 { width: 60%; }
  .w75 { width: 75%; }
  .w90 { width: 90%; }
  .slide-mock-footer {
    height: 4px;
    width: 20%;
    background: var(--border);
    border-radius: 2px;
    align-self: flex-end;
  }
  .slide-note {
    font-size: 0.75rem;
    color: var(--fg-3);
  }
</style>
