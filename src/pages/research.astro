---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import RepoStats from '../components/RepoStats.astro';

const replications = (await getCollection('replications')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

function authorsLine(rep: (typeof replications)[number]): string {
  if (rep.data.authors && rep.data.authors.length > 0) {
    return rep.data.authors.join(', ');
  }
  // Fallback: parse first segment of paper string up to the year or a period
  if (rep.data.paper) {
    const match = rep.data.paper.match(/^([^(]+)\(/);
    if (match) return match[1].trim().replace(/\.$/, '');
    return rep.data.paper.split('.')[0].trim();
  }
  return '';
}

function venueYear(rep: (typeof replications)[number]): string {
  const parts: string[] = [];
  if (rep.data.venue) parts.push(rep.data.venue);
  if (rep.data.year) parts.push(`(${rep.data.year})`);
  return parts.join(' ');
}

const projects = [
  {
    title: 'DLM (2005) Virtual Trading Platform',
    dates: '2025–present',
    description:
      'Browser-based replication of Dufwenberg, Lindqvist & Moore (AER 2005) asset market bubble experiment. Three-plan factorial: algorithmic belief update, LLM + utility forms, LLM + risk label. Interactive dashboard with 12 chart figures, agent cards, order book, trade feed, and replay.',
    tags: ['experimental-economics', 'market-microstructure', 'LLM', 'replication'],
    links: [{ label: 'Launch Simulator →', href: '/simulator', external: false }],
  },
  {
    title: 'Collective Trades',
    dates: '2025–present',
    description:
      'Real-time dashboard for insider trades, institutional holdings, and congressional disclosures. FastAPI backend (Heroku) proxies to a Mac Mini data pipeline; Next.js frontend with network-graph explorer, candlestick charts, and Discord bot integration.',
    tags: ['fintech', 'fastapi', 'next.js', 'market-data'],
    links: [],
    meta: 'Stack: FastAPI · PostgreSQL · Redis · Next.js',
  },
  {
    title: 'Digital Transactions in Asia VII — Call for Papers',
    dates: '2025',
    description:
      'Conference website for the 7th edition of the Digital Transactions in Asia workshop (University of Peradeniya, Sri Lanka). Next.js site with admin panel, paper submission and registration workflow, showcase management, and public schedule.',
    tags: ['conference', 'next.js', 'drizzle-orm', 'digital-finance'],
    links: [{ label: 'Visit site →', href: 'https://www.icdtaaussl2026.com', external: true }],
  },
];
---

<BaseLayout title="Research — Joshua Lee">
  <header class="page-header">
    <h1 class="page-title">Research &amp; Projects</h1>
    <p class="page-subtitle">
      A methods archive for empirical finance research — building an open-source alternative to tidyfinance.
    </p>
  </header>

  <div class="repo-stats-row">
    <RepoStats owner="uqslee65" repo="phd-finance-replications" />
  </div>

  <!-- Projects -->
  <section class="page-section">
    <h2 class="section-heading">Projects</h2>
    <div class="project-list">
      {projects.map(p => (
        <div class="card project-card">
          <div class="project-meta">
            <span class="project-dates">{p.dates}</span>
          </div>
          <div class="project-body">
            <h3 class="project-title">{p.title}</h3>
            <p class="project-desc">{p.description}</p>
            <div class="tag-row">
              {p.tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
            <div class="project-footer">
              {p.meta && <span class="project-meta-note">{p.meta}</span>}
              {p.links.map(link => (
                <a
                  href={link.href}
                  class="action-btn action-btn--primary"
                  {...(link.external ? { target: '_blank', rel: 'noopener' } : {})}
                >
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Replications -->
  <section class="page-section">
    <h2 class="section-heading">Replications</h2>
    {replications.length === 0 ? (
      <p class="empty-state">No replications yet.</p>
    ) : (
      <div class="rep-list">
        {replications.map(rep => {
          const authors = authorsLine(rep);
          const vy = venueYear(rep);
          return (
            <div class="card rep-card">
              <div class="rep-top">
                <div class="rep-title-row">
                  <a href={`/replications/${rep.id}`} class="rep-title-link">
                    {rep.data.title}
                  </a>
                  <span class={`status-badge status-badge--${rep.data.status}`}>
                    {rep.data.status}
                  </span>
                </div>
                {authors && <div class="rep-authors">{authors}</div>}
                {vy && <div class="rep-venue">{vy}</div>}
              </div>
              {rep.data.tags.length > 0 && (
                <div class="tag-row">
                  {rep.data.tags.map(tag => <span class="tag">{tag}</span>)}
                </div>
              )}
              <div class="rep-actions">
                {rep.data.slides_url ? (
                  <a href={rep.data.slides_url} class="action-btn action-btn--ghost" target="_blank" rel="noopener">Slides</a>
                ) : (
                  <span class="action-btn action-btn--disabled">Slides</span>
                )}
                {rep.data.notebook_url ? (
                  <a href={rep.data.notebook_url} class="action-btn action-btn--ghost" target="_blank" rel="noopener">Notebook</a>
                ) : (
                  <span class="action-btn action-btn--disabled">Notebook</span>
                )}
                <a href={`/replications/${rep.id}`} class="action-btn action-btn--primary">View →</a>
              </div>
            </div>
          );
        })}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  /* Page header */
  .page-header {
    padding-top: 2rem;
    padding-bottom: 0.5rem;
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
    margin-bottom: 1.5rem;
  }
  .page-title {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--fg);
    line-height: 1.15;
  }
  .page-subtitle {
    font-size: 0.9rem;
    color: var(--fg-2);
    margin-top: 0.5rem;
    max-width: 44rem;
    line-height: 1.55;
  }

  /* Repo stats row */
  .repo-stats-row {
    margin-bottom: 2.5rem;
  }

  /* Sections */
  .page-section {
    margin-bottom: 3rem;
  }
  .section-heading {
    font-size: 1rem;
    font-weight: 700;
    color: var(--fg-2);
    letter-spacing: 0.04em;
    margin-bottom: 1.25rem;
    text-transform: none;
  }

  /* Card base */
  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    transition: box-shadow 0.15s, transform 0.15s;
  }
  .card:hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-1px);
  }

  /* Project cards */
  .project-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .project-card {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: 0;
  }
  .project-meta {
    padding: 1.25rem 0 1.25rem 1.25rem;
    border-right: 1px solid var(--border);
  }
  .project-dates {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.78rem;
    color: var(--fg-3);
    white-space: nowrap;
  }
  .project-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .project-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--fg);
  }
  .project-desc {
    font-size: 0.875rem;
    color: var(--fg-2);
    line-height: 1.55;
    margin: 0;
  }
  .project-footer {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }
  .project-meta-note {
    font-size: 0.78rem;
    color: var(--fg-3);
  }

  /* Tag pills */
  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .tag {
    font-size: 0.68rem;
    padding: 0.2rem 0.55rem;
    border-radius: 9999px;
    border: 1px solid var(--border);
    background: var(--stat-bg);
    color: var(--fg-2);
    font-weight: 500;
  }

  /* Action buttons */
  .action-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }
  .action-btn--primary {
    background: var(--accent);
    color: #fff;
  }
  .action-btn--primary:hover {
    background: var(--accent-hover);
  }
  .action-btn--ghost {
    background: var(--stat-bg);
    color: var(--fg-2);
    border: 1px solid var(--border);
  }
  .action-btn--ghost:hover {
    background: var(--border);
    color: var(--fg);
  }
  .action-btn--disabled {
    background: var(--stat-bg);
    color: var(--fg-3);
    border: 1px solid var(--border);
    cursor: not-allowed;
    opacity: 0.6;
  }

  /* Replication list */
  .rep-list {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }
  .rep-card {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .rep-top {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .rep-title-row {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .rep-title-link {
    font-size: 0.975rem;
    font-weight: 600;
    color: var(--fg);
    text-decoration: none;
    flex: 1;
    min-width: 0;
    line-height: 1.35;
  }
  .rep-title-link:hover {
    color: var(--accent);
  }
  .rep-authors {
    font-size: 0.82rem;
    color: var(--fg-2);
  }
  .rep-venue {
    font-size: 0.78rem;
    color: var(--fg-3);
    font-style: italic;
  }
  .rep-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.1rem;
  }

  /* Status badges */
  .status-badge {
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.2rem 0.55rem;
    border-radius: 9999px;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .status-badge--complete {
    background: var(--success-bg);
    color: var(--success);
  }
  .status-badge--partial {
    background: var(--warning-bg);
    color: var(--warning);
  }
  .status-badge--planned {
    background: var(--stat-bg);
    color: var(--fg-3);
    border: 1px solid var(--border);
  }

  /* Empty state */
  .empty-state {
    font-size: 0.875rem;
    color: var(--fg-3);
  }

  /* Mobile */
  @media (max-width: 600px) {
    .project-card {
      grid-template-columns: 1fr;
    }
    .project-meta {
      border-right: none;
      border-bottom: 1px solid var(--border);
      padding: 0.75rem 1.25rem 0.5rem;
    }
  }
</style>
