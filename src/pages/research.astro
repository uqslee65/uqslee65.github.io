---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import TabBar from '../components/TabBar.astro';
import StatsBar from '../components/StatsBar';

const replications = (await getCollection('replications')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const siteStats = [
  { value: 3, label: 'Projects' },
  { value: replications.length, label: 'Replications' },
  { value: replications.filter(r => r.data.status === 'complete').length, label: 'Complete' },
];
---

<BaseLayout title="Research — Josh">
  <h1 class="page-heading">Research &amp; Projects</h1>

  <StatsBar stats={siteStats} client:load />

  <TabBar tabs={['Projects', 'Replications']} />

  <div data-tab-content="Projects" class="tab-panel">
    <div class="timeline">
      <div class="timeline-entry card">
        <div class="timeline-date">2025–present</div>
        <div class="timeline-body">
          <div class="project-title">DLM (2005) Virtual Trading Platform</div>
          <p class="project-desc">
            Browser-based replication of Dufwenberg, Lindqvist &amp; Moore (AER 2005)
            asset market bubble experiment. Three-plan factorial: algorithmic belief
            update, LLM + utility forms, LLM + risk label. Interactive dashboard
            with 12 chart figures, agent cards, order book, trade feed, and replay.
          </p>
          <div class="tag-row">
            <span class="tag">experimental-economics</span>
            <span class="tag">market-microstructure</span>
            <span class="tag">LLM</span>
            <span class="tag">replication</span>
          </div>
          <div class="project-footer">
            <span class="slides-label">Slides: <span class="muted">N/A</span></span>
            <a href="/simulator" class="launch-link">Launch Simulator →</a>
          </div>
        </div>
      </div>

      <div class="timeline-entry card">
        <div class="timeline-date">2025–present</div>
        <div class="timeline-body">
          <div class="project-title">Collective Trades</div>
          <p class="project-desc">
            Real-time dashboard for insider trades, institutional holdings, and
            congressional disclosures. FastAPI backend (Heroku) proxies to a Mac Mini
            data pipeline; Next.js frontend with network-graph explorer, candlestick
            charts, and Discord bot integration. Ko-fi donation gateway.
          </p>
          <div class="tag-row">
            <span class="tag">fintech</span>
            <span class="tag">fastapi</span>
            <span class="tag">next.js</span>
            <span class="tag">market-data</span>
          </div>
          <div class="project-footer">
            <span class="slides-label">Stack: FastAPI · PostgreSQL · Redis · Next.js</span>
          </div>
        </div>
      </div>

      <div class="timeline-entry card">
        <div class="timeline-date">2025</div>
        <div class="timeline-body">
          <div class="project-title">Digital Transactions in Asia VII — Call for Papers</div>
          <p class="project-desc">
            Conference website for the 7th edition of the Digital Transactions in Asia
            workshop (University of Peradeniya, Sri Lanka). Next.js site with admin
            panel, paper submission and registration workflow, showcase management,
            and public schedule. Live at icdtaaussl2026.com.
          </p>
          <div class="tag-row">
            <span class="tag">conference</span>
            <span class="tag">next.js</span>
            <span class="tag">drizzle-orm</span>
            <span class="tag">digital-finance</span>
          </div>
          <div class="project-footer">
            <a href="https://www.icdtaaussl2026.com" class="launch-link" target="_blank" rel="noopener">Visit site →</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div data-tab-content="Replications" class="tab-panel" style="display:none">
    {replications.length === 0 ? (
      <p class="empty-state">No replications yet.</p>
    ) : (
      <div class="replication-list">
        {replications.map(rep => (
          <a href={`/replications/${rep.id}`} class="replication-card card">
            <div class="rep-header">
              <span class={`rep-status rep-status--${rep.data.status}`}>{rep.data.status}</span>
              <span class="rep-date">{rep.data.date}</span>
            </div>
            <div class="rep-title">{rep.data.title}</div>
            <div class="rep-paper">{rep.data.paper}</div>
            {rep.data.tags.length > 0 && (
              <div class="tag-row">
                {rep.data.tags.map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .page-heading {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--fg);
    margin-bottom: 1.5rem;
    padding-top: 1rem;
    border-left: 4px solid var(--accent);
    padding-left: 1rem;
  }
  .tab-panel {
    padding-top: 1.5rem;
  }

  /* Timeline */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .timeline-entry.card {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: 1rem;
    padding: 1.25rem;
    border-radius: 0;
    box-shadow: none;
    border: 2px solid var(--border);
    transition: border-color 0.15s;
  }
  .timeline-entry.card:hover {
    border-color: var(--fg);
    transform: none;
  }
  .timeline-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--fg-3);
    padding-top: 0.15rem;
    white-space: nowrap;
  }
  .timeline-body {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .project-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--fg);
    text-transform: none;
  }
  .project-desc {
    font-size: 0.875rem;
    color: var(--fg-2);
    line-height: 1.55;
    margin: 0;
  }
  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .project-footer {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }
  .slides-label {
    font-size: 0.8rem;
    color: var(--fg-2);
  }
  .muted {
    color: var(--fg-3);
  }

  /* Launch link — Swiss Grid: dark pill, no radius */
  .launch-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.35rem 0.75rem;
    font-size: 0.7rem;
    font-weight: 600;
    background: var(--fg);
    color: var(--bg);
    border-radius: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: background 0.15s;
    text-decoration: none;
  }
  .launch-link:hover {
    background: var(--accent);
    color: var(--bg);
  }

  /* Empty state */
  .empty-state {
    font-size: 0.875rem;
    color: var(--fg-3);
    margin: 0;
  }

  /* Replication cards */
  .replication-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .replication-card.card {
    display: block;
    text-decoration: none;
    padding: 1.25rem;
    border-radius: 0;
    box-shadow: none;
    border: 1px solid var(--border);
    transition: border-color 0.15s;
  }
  .replication-card.card:hover {
    border-color: var(--fg);
  }
  .rep-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.4rem;
  }
  .rep-status {
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .rep-status--complete { background: rgba(34,197,94,0.15); color: #4ade80; }
  .rep-status--partial { background: rgba(234,179,8,0.15); color: #facc15; }
  .rep-status--planned { background: var(--stat-bg); color: var(--fg-3); }
  .rep-date {
    font-size: 0.75rem;
    color: var(--fg-3);
  }
  .rep-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--fg);
    margin-bottom: 0.2rem;
  }
  .rep-paper {
    font-size: 0.8rem;
    color: var(--fg-3);
    margin-bottom: 0.5rem;
  }

  /* Mobile: collapse date into stacked layout */
  @media (max-width: 640px) {
    .timeline-entry.card {
      grid-template-columns: 1fr;
    }
  }
</style>
