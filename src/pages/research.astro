---
import BaseLayout from '../layouts/BaseLayout.astro';
import RepoStats from '../components/RepoStats.astro';

const projects = [
  {
    title: 'DLM (2005) Virtual Trading Platform',
    dates: '2025–present',
    description:
      'Browser-based replication of Dufwenberg, Lindqvist & Moore (AER 2005) asset market bubble experiment. Three-plan factorial: algorithmic belief update, LLM + utility forms, LLM + risk label. Interactive dashboard with 12 chart figures, agent cards, order book, trade feed, and replay.',
    tags: ['experimental-economics', 'market-microstructure', 'LLM', 'replication'],
    links: [{ label: 'Launch Simulator →', href: '/simulator', external: false }],
  },
  {
    title: 'Collective Trades',
    dates: '2025–present',
    description:
      'Real-time dashboard for insider trades, institutional holdings, and congressional disclosures. FastAPI backend (Heroku) proxies to a Mac Mini data pipeline; Next.js frontend with network-graph explorer, candlestick charts, and Discord bot integration.',
    tags: ['fintech', 'fastapi', 'next.js', 'market-data'],
    links: [],
    meta: 'Stack: FastAPI · PostgreSQL · Redis · Next.js',
  },
  {
    title: 'Digital Transactions in Asia VII — Call for Papers',
    dates: '2025',
    description:
      'Conference website for the 7th edition of the Digital Transactions in Asia workshop (University of Peradeniya, Sri Lanka). Next.js site with admin panel, paper submission and registration workflow, showcase management, and public schedule.',
    tags: ['conference', 'next.js', 'drizzle-orm', 'digital-finance'],
    links: [{ label: 'Visit site →', href: 'https://www.icdtaaussl2026.com', external: true }],
  },
];
---

<BaseLayout title="Research — Joshua Lee">
  <header class="page-header">
    <h1 class="page-title">Research &amp; Projects</h1>
    <p class="page-subtitle">
      A methods archive for empirical finance research — building an open-source alternative to tidyfinance.
    </p>
  </header>

  <div class="repo-stats-row">
    <RepoStats owner="uqslee65" repo="phd-finance-replications" />
  </div>

  <!-- Projects -->
  <section class="page-section">
    <h2 class="section-heading">Projects</h2>
    <div class="project-list">
      {projects.map(p => (
        <div class="card project-card">
          <div class="project-meta">
            <span class="project-dates">{p.dates}</span>
          </div>
          <div class="project-body">
            <h3 class="project-title">{p.title}</h3>
            <p class="project-desc">{p.description}</p>
            <div class="tag-row">
              {p.tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
            <div class="project-footer">
              {p.meta && <span class="project-meta-note">{p.meta}</span>}
              {p.links.map(link => (
                <a
                  href={link.href}
                  class="action-btn"
                  {...(link.external ? { target: '_blank', rel: 'noopener' } : {})}
                >
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  /* Page header */
  .page-header {
    padding-top: 2rem;
    padding-bottom: 0.5rem;
    border-left: 3px solid var(--border);
    padding-left: 1rem;
    margin-bottom: 1.5rem;
  }
  .page-title {
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.2em;
    color: var(--text-faint);
    text-transform: uppercase;
  }
  .page-subtitle {
    font-size: 0.9rem;
    color: var(--text-dim);
    margin-top: 0.5rem;
    max-width: 44rem;
    line-height: 1.55;
  }

  /* Repo stats row */
  .repo-stats-row {
    margin-bottom: 2.5rem;
  }

  /* Sections */
  .page-section {
    margin-bottom: 3rem;
  }
  .section-heading {
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.2em;
    color: var(--text-faint);
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  /* Card base */
  .card {
    background: var(--bg-raised);
    border: 1px solid var(--border);
    transition: opacity 0.15s;
  }
  .card:hover {
    opacity: 0.9;
  }

  /* Project cards */
  .project-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .project-card {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: 0;
  }
  .project-meta {
    padding: 1.25rem 0 1.25rem 1.25rem;
    border-right: 1px solid var(--border);
  }
  .project-dates {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.78rem;
    color: var(--text-faint);
    white-space: nowrap;
  }
  .project-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .project-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
  }
  .project-desc {
    font-size: 0.875rem;
    color: var(--text-dim);
    line-height: 1.55;
    margin: 0;
  }
  .project-footer {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }
  .project-meta-note {
    font-size: 0.78rem;
    color: var(--text-faint);
  }

  /* Tag pills */
  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .tag {
    font-size: 0.68rem;
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--border);
    background: var(--bg-surface);
    color: var(--text-dim);
    font-weight: 500;
  }

  /* Action buttons */
  .action-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.75rem;
    font-size: 11px;
    font-weight: 400;
    text-decoration: none;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: color 0.15s, border-color 0.15s;
  }
  .action-btn:hover {
    color: var(--text);
    border-color: var(--text-dim);
  }

  /* Mobile */
  @media (max-width: 600px) {
    .project-card {
      grid-template-columns: 1fr;
    }
    .project-meta {
      border-right: none;
      border-bottom: 1px solid var(--border);
      padding: 0.75rem 1.25rem 0.5rem;
    }
  }
</style>
