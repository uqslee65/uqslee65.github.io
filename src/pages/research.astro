---
import BaseLayout from '../layouts/BaseLayout.astro';
import TabBar from '../components/TabBar.astro';
---

<BaseLayout title="Research — Josh">
  <h1 class="page-heading">Research &amp; Projects</h1>

  <TabBar tabs={['Projects', 'Replications']} />

  <div data-tab-content="Projects" class="tab-panel">
    <div class="timeline">
      <div class="timeline-entry card">
        <div class="timeline-date">2025–present</div>
        <div class="timeline-body">
          <div class="project-title">DLM (2005) Virtual Trading Platform</div>
          <p class="project-desc">
            Browser-based replication of Dufwenberg, Lindqvist &amp; Moore (AER 2005)
            asset market bubble experiment. Three-plan factorial: algorithmic belief
            update, LLM + utility forms, LLM + risk label. Interactive dashboard
            with 12 chart figures, agent cards, order book, trade feed, and replay.
          </p>
          <div class="tag-row">
            <span class="tag">experimental-economics</span>
            <span class="tag">market-microstructure</span>
            <span class="tag">LLM</span>
            <span class="tag">replication</span>
          </div>
          <div class="project-footer">
            <span class="slides-label">Slides: <span class="muted">N/A</span></span>
            <a href="/simulator" class="launch-link">Launch Simulator →</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div data-tab-content="Replications" class="tab-panel" style="display:none">
    <p class="empty-state">No replications yet.</p>
  </div>
</BaseLayout>

<style>
  .page-heading {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--fg);
    margin-bottom: 1.5rem;
    padding-top: 1rem;
  }
  .tab-panel {
    padding-top: 1.5rem;
  }

  /* Timeline */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .timeline-entry {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: 1rem;
    padding: 1.25rem;
  }
  .timeline-date {
    font-family: monospace;
    font-size: 0.8rem;
    color: var(--fg-3);
    padding-top: 0.15rem;
    white-space: nowrap;
  }
  .timeline-body {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .project-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--fg);
  }
  .project-desc {
    font-size: 0.875rem;
    color: var(--fg-2);
    line-height: 1.55;
    margin: 0;
  }
  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .project-footer {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }
  .slides-label {
    font-size: 0.8rem;
    color: var(--fg-2);
  }
  .muted {
    color: var(--fg-3);
  }

  /* Launch Simulator button */
  .launch-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.35rem 0.75rem;
    font-size: 0.8rem;
    font-weight: 600;
    background: var(--accent);
    color: white;
    border-radius: 6px;
    transition: background 0.15s;
    text-decoration: none;
  }
  .launch-link:hover {
    background: var(--accent-hover);
    color: white;
  }

  /* Empty state */
  .empty-state {
    font-size: 0.875rem;
    color: var(--fg-3);
    margin: 0;
  }

  /* Mobile: collapse date into stacked layout */
  @media (max-width: 640px) {
    .timeline-entry {
      grid-template-columns: 1fr;
    }
  }
</style>
