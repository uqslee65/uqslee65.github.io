---
import BaseLayout from '../layouts/BaseLayout.astro';
import { RESUME } from '../data/resume.ts';
---

<BaseLayout title="About — Joshua Lee">
  <header class="about-header">
    <div class="about-header-main">
      <div class="about-name-row">
        <h1 class="about-name">Joshua Lee</h1>
        <div class="view-toggle" id="view-toggle">
          <button class="toggle-btn active" data-view="academic">ACADEMIC</button>
          <button class="toggle-btn" data-view="industry">INDUSTRY</button>
        </div>
      </div>
      <p class="about-title">{RESUME.contact.title}</p>
      <div class="interest-chips">
        {RESUME.researchInterests.map(interest => (
          <span class="tag">{interest}</span>
        ))}
      </div>
    </div>
    <div class="about-photo-wrap">
      <img src="/headshot.png" alt="Joshua Lee" class="about-photo" />
      <div class="about-contact-card">
        <a href={RESUME.contact.linkedin} target="_blank" rel="noopener" class="about-contact-row">
          <span class="about-contact-type">LinkedIn</span>
          <span class="about-contact-val">leeszeray</span>
        </a>
        <a href={`mailto:${RESUME.contact.email}`} class="about-contact-row">
          <span class="about-contact-type">Email</span>
          <span class="about-contact-val">{RESUME.contact.email}</span>
        </a>
        <a href={`tel:${RESUME.contact.phone.replace(/\s/g, '')}`} class="about-contact-row">
          <span class="about-contact-type">Phone</span>
          <span class="about-contact-val">{RESUME.contact.phone}</span>
        </a>
        <a href={RESUME.contact.github} target="_blank" rel="noopener" class="about-contact-row">
          <span class="about-contact-type">GitHub</span>
          <span class="about-contact-val">uqslee65</span>
        </a>
      </div>
    </div>
  </header>

  <div id="cv-container" data-view="academic">
    <!-- Academic nav: 8 links -->
    <nav class="section-nav section-nav--academic">
      <a href="#education" class="section-nav-link">Education</a>
      <a href="#research" class="section-nav-link">Research</a>
      <a href="#teaching" class="section-nav-link">Teaching</a>
      <a href="#experience" class="section-nav-link">Experience</a>
      <a href="#thesis" class="section-nav-link">Thesis</a>
      <a href="#honours" class="section-nav-link">Honours</a>
      <a href="#service" class="section-nav-link">Service</a>
      <a href="#skills" class="section-nav-link">Skills</a>
    </nav>
    <!-- Industry nav: 4 links -->
    <nav class="section-nav section-nav--industry">
      <a href="#education" class="section-nav-link">Education</a>
      <a href="#experience" class="section-nav-link">Experience</a>
      <a href="#extracurriculars" class="section-nav-link">Extracurriculars</a>
      <a href="#skills" class="section-nav-link">Skills</a>
    </nav>

    <!-- Education (both views) -->
    <section id="education" class="cv-section">
      <h2 class="section-heading">EDUCATION</h2>
      {RESUME.education.map(entry => (
        <details class="edu-entry">
          <summary class="edu-summary">
            <span class="edu-degree">{entry.degree}</span>
            <span class="edu-meta"> — {entry.institution} · {entry.period}</span>
          </summary>
          <div class="edu-body">
            {entry.grade && <p class="edu-detail">GPA: {entry.grade}</p>}
            {entry.thesis && <p class="edu-detail">Thesis: <em>{entry.thesis}</em></p>}
            {entry.advisors && entry.advisors.length > 0 && (
              <p class="edu-detail">Advisors: {entry.advisors.join(', ')}</p>
            )}
            {entry.topics && entry.topics.length > 0 && (
              <p class="edu-detail">Topics: {entry.topics.join(', ')}</p>
            )}
            {entry.awards && entry.awards.length > 0 && (
              <ul class="edu-list">
                {entry.awards.map(a => <li>{a}</li>)}
              </ul>
            )}
            {entry.achievements && entry.achievements.length > 0 && (
              <ul class="edu-list">
                {entry.achievements.map(a => <li>{a}</li>)}
              </ul>
            )}
          </div>
        </details>
      ))}
    </section>

    <!-- Research (academic only) -->
    <section id="research" class="cv-section academic-only">
      <h2 class="section-heading">RESEARCH</h2>
      {RESUME.research.map(entry => (
        <div class="timeline-entry">
          <span class="timeline-date">{entry.period}</span>
          <div class="timeline-content">
            <span class="entry-title">{entry.role}</span>
            {' · '}
            <span class="entry-org">{entry.organisation}</span>
            <p class="entry-detail">{entry.details}</p>
          </div>
        </div>
      ))}
      {RESUME.researchProjects.map(project => (
        <div class="timeline-entry">
          <span class="timeline-date">{project.period}</span>
          <div class="timeline-content">
            <span class="entry-title">{project.title}</span>
            {' · '}
            <span class="entry-org">{project.organisation}</span>
            <p class="entry-detail">{project.details}</p>
          </div>
        </div>
      ))}
    </section>

    <!-- Teaching (academic only) -->
    <section id="teaching" class="cv-section academic-only">
      <h2 class="section-heading">TEACHING</h2>
      {RESUME.teaching.map(entry => (
        <div class="timeline-entry">
          <span class="timeline-date">{entry.period}</span>
          <div class="timeline-content">
            <span class="entry-title">{entry.role}</span>
            {' · '}
            <span class="entry-org">{entry.organisation}</span>
            <p class="entry-detail">{entry.details}</p>
          </div>
        </div>
      ))}
    </section>

    <!-- Experience (both views) -->
    <section id="experience" class="cv-section">
      <h2 class="section-heading">EXPERIENCE</h2>
      {RESUME.financeExperience.map(entry => (
        <div class="timeline-entry">
          <span class="timeline-date">{entry.period}</span>
          <div class="timeline-content">
            <span class="entry-title">{entry.role}</span>
            {' · '}
            <span class="entry-org">{entry.organisation}</span>
            <p class="entry-detail">{entry.details}</p>
          </div>
        </div>
      ))}
    </section>

    <!-- Thesis (academic only) -->
    <section id="thesis" class="cv-section academic-only">
      <h2 class="section-heading">THESIS</h2>
      <div class="thesis-block">
        <p class="thesis-title">{RESUME.thesis.title}</p>
        <p class="thesis-meta">{RESUME.thesis.degree} · {RESUME.thesis.institution} · {RESUME.thesis.year}</p>
      </div>
    </section>

    <!-- Honours (academic only) -->
    <section id="honours" class="cv-section academic-only">
      <h2 class="section-heading">HONOURS & AWARDS</h2>
      {RESUME.honours.map(group => (
        <div class="honours-group">
          <h4 class="group-heading">{group.group}</h4>
          <ul class="entry-list">
            {group.items.map(item => <li>{item}</li>)}
          </ul>
        </div>
      ))}
    </section>

    <!-- Service (academic only) -->
    <section id="service" class="cv-section academic-only">
      <h2 class="section-heading">SERVICE</h2>
      {RESUME.academicService.map(entry => (
        <div class="timeline-entry">
          <span class="timeline-date">{entry.period}</span>
          <div class="timeline-content">
            <span class="entry-title">{entry.role}</span>
            {' · '}
            <span class="entry-org">{entry.organisation}</span>
            <p class="entry-detail">{entry.details}</p>
          </div>
        </div>
      ))}
      {RESUME.volunteering.filter(v => v.organisation === "UQ Commerce Student Committee").map(entry => (
        <div class="timeline-entry">
          <span class="timeline-date">{entry.period}</span>
          <div class="timeline-content">
            <span class="entry-title">{entry.role}</span>
            {' · '}
            <span class="entry-org">{entry.organisation}</span>
            {entry.bullets && entry.bullets.length > 0 ? (
              <ul class="entry-bullets">
                {entry.bullets.map(b => <li>{b}</li>)}
              </ul>
            ) : (
              <p class="entry-detail">{entry.details}</p>
            )}
          </div>
        </div>
      ))}
    </section>

    <!-- Extracurriculars (industry only) -->
    <section id="extracurriculars" class="cv-section industry-only">
      <h2 class="section-heading">EXTRACURRICULARS</h2>
      {RESUME.volunteering.map(entry => (
        <div class="timeline-entry">
          <span class="timeline-date">{entry.period}</span>
          <div class="timeline-content">
            <span class="entry-title">{entry.role}</span>
            {' · '}
            <span class="entry-org">{entry.organisation}</span>
            {entry.bullets && entry.bullets.length > 0 ? (
              <ul class="entry-bullets">
                {entry.bullets.map(b => <li>{b}</li>)}
              </ul>
            ) : (
              <p class="entry-detail">{entry.details}</p>
            )}
          </div>
        </div>
      ))}
    </section>

    <!-- Skills (both views) -->
    <section id="skills" class="cv-section">
      <h2 class="section-heading">SKILLS</h2>
      <div class="skill-chips">
        {RESUME.skills.map(skill => (
          <span class="tag">{skill}</span>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  const container = document.getElementById('cv-container');
  const buttons = document.querySelectorAll('.toggle-btn');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const view = btn.getAttribute('data-view');
      if (!view || !container) return;
      container.setAttribute('data-view', view);
      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    });
  });

  const navLinks = document.querySelectorAll('.section-nav-link');
  const sectionEls = document.querySelectorAll('.cv-section[id]');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          navLinks.forEach(link => {
            link.classList.toggle('active', link.getAttribute('href') === `#${entry.target.id}`);
          });
        }
      });
    },
    { rootMargin: '-20% 0px -60% 0px' }
  );

  sectionEls.forEach(section => observer.observe(section));
</script>

<style>
  .about-header {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: start;
    margin-bottom: 2rem;
  }
  .about-header-main {
    min-width: 0;
  }
  .about-name-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .about-name {
    font-size: 2rem;
    font-weight: 300;
    color: var(--text);
    letter-spacing: -0.02em;
  }
  .about-title {
    font-size: 0.8rem;
    color: var(--text-dim);
    margin-top: 0.25rem;
  }
  .interest-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 1rem;
  }
  .about-photo-wrap {
    flex-shrink: 0;
  }
  .about-photo {
    width: 160px;
    height: auto;
    display: block;
    filter: brightness(0.92);
  }
  .about-contact-card {
    margin-top: 0.75rem;
    border: 1px solid var(--border);
    width: 160px;
  }
  .about-contact-row {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    padding: 0.5rem 0.6rem;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: background 0.15s;
  }
  .about-contact-row:last-child { border-bottom: none; }
  .about-contact-row:hover { background: var(--bg-surface); }
  .about-contact-type {
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    color: var(--text-faint);
  }
  .about-contact-val {
    font-size: 10px;
    color: var(--text-dim);
    word-break: break-all;
  }

  .section-nav {
    display: flex;
    gap: 0.25rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1.5rem;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .section-nav::-webkit-scrollbar { display: none; }
  .section-nav-link {
    padding: 0.5rem 0.75rem;
    font-size: 10px;
    font-weight: 400;
    color: var(--text-dim);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    border-bottom: 1px solid transparent;
    white-space: nowrap;
    transition: color 0.15s, border-color 0.15s;
  }
  .section-nav-link:hover { color: var(--text); }
  .section-nav-link.active {
    color: var(--text);
    border-bottom-color: var(--text);
  }

  .view-toggle {
    display: flex;
    gap: 0;
  }
  .toggle-btn {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.5rem 1rem;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-faint);
    cursor: pointer;
    transition: color 0.15s, background 0.15s, border-color 0.15s;
  }
  .toggle-btn:first-child { border-right: none; }
  .toggle-btn.active {
    color: var(--text);
    background: var(--bg-surface);
    border-color: var(--border-mid);
  }

  /* Dual nav visibility */
  [data-view="academic"] .section-nav--industry { display: none; }
  [data-view="industry"] .section-nav--academic { display: none; }

  [data-view="industry"] :global(.academic-only) { display: none !important; }
  [data-view="academic"] :global(.industry-only) { display: none !important; }

  .cv-section {
    margin-bottom: 2.5rem;
    scroll-margin-top: calc(var(--nav-height) + 2rem);
  }
  .section-heading {
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.16em;
    color: var(--text-faint);
    text-transform: uppercase;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .edu-entry { margin-bottom: 0.5rem; }
  .edu-summary {
    padding: 0.6rem 0;
    cursor: pointer;
    list-style: none;
    border-bottom: 1px solid var(--border);
    user-select: none;
    font-size: 0.875rem;
    line-height: 1.4;
  }
  .edu-summary::-webkit-details-marker { display: none; }
  .edu-summary::marker { content: ''; }
  .edu-summary::before {
    content: '+';
    display: inline-block;
    margin-right: 0.6rem;
    font-size: 0.8rem;
    color: var(--text-faint);
    width: 0.8rem;
  }
  .edu-entry[open] .edu-summary::before { content: '−'; }
  .edu-degree { font-weight: 600; color: var(--text); }
  .edu-meta { color: var(--text-faint); font-size: 0.8rem; }
  .edu-body { padding: 0.75rem 0 0.5rem 1.4rem; }
  .edu-detail {
    font-size: 0.8rem;
    color: var(--text-dim);
    margin-bottom: 0.2rem;
    line-height: 1.5;
  }
  .edu-list {
    margin: 0.3rem 0 0 1rem;
    padding: 0;
    font-size: 0.78rem;
    color: var(--text-faint);
    list-style: disc;
    line-height: 1.6;
  }
  .edu-list li { padding: 0.05rem 0; }

  .timeline-entry {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: 0.75rem;
    padding: 0.5rem 0;
  }
  .timeline-date {
    font-size: 0.75rem;
    color: var(--text-faint);
    font-family: 'JetBrains Mono', monospace;
    text-align: right;
    white-space: nowrap;
    padding-top: 0.1rem;
  }
  .timeline-content {
    font-size: 0.875rem;
    color: var(--text-dim);
    line-height: 1.5;
    border-left: 1px solid var(--border);
    padding-left: 0.75rem;
  }
  .entry-title { font-weight: 600; color: var(--text); }
  .entry-org { color: var(--text-dim); }
  .entry-detail {
    font-size: 0.8rem;
    color: var(--text-faint);
    margin-top: 0.2rem;
    line-height: 1.5;
  }

  .honours-group { margin-bottom: 0.75rem; }
  .group-heading {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-dim);
    margin: 0 0 0.25rem;
    border-left: 2px solid var(--text-faint);
    padding-left: 0.5rem;
  }
  .entry-list {
    margin: 0.25rem 0 0 1rem;
    padding: 0;
    font-size: 0.78rem;
    color: var(--text-faint);
    list-style: disc;
  }
  .entry-list li { padding: 0.05rem 0; }

  .skill-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  /* Thesis block */
  .thesis-block {
    padding: 1rem 0;
    border-left: 2px solid var(--border-mid);
    padding-left: 1rem;
  }
  .thesis-title {
    font-size: 0.9rem;
    color: var(--text);
    font-weight: 500;
    line-height: 1.5;
    margin-bottom: 0.35rem;
  }
  .thesis-meta {
    font-size: 0.78rem;
    color: var(--text-faint);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* Bullet list in timeline entries */
  .entry-bullets {
    margin: 0.3rem 0 0 1rem;
    padding: 0;
    list-style: disc;
    font-size: 0.78rem;
    color: var(--text-faint);
    line-height: 1.6;
  }
  .entry-bullets li { padding: 0.05rem 0; }

  @media (max-width: 768px) {
    .about-photo-wrap {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .about-header {
      grid-template-columns: 1fr;
    }
    .timeline-entry {
      grid-template-columns: 5.5rem 1fr;
      gap: 0.5rem;
    }
    .timeline-date { font-size: 0.72rem; }
  }
</style>
