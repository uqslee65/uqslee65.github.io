---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Carousel } from '../components/Carousel.tsx';
import DashboardStats from '../components/DashboardStats.tsx';
import GitHubActivity from '../components/GitHubActivity.tsx';
---

<BaseLayout title="Dashboard — Joshua Lee">
  <header class="dash-header">
    <h1>DASHBOARD</h1>
    <p>Research activity and project overview.</p>
  </header>

  <!-- Stats -->
  <section class="dash-section">
    <DashboardStats client:load />
  </section>

  <!-- Featured Projects Carousel -->
  <section class="dash-section">
    <h2 class="section-label">FEATURED PROJECTS</h2>
    <Carousel client:load items={[
      {
        title: 'DLM (2005) Bubble Simulator',
        description: 'Interactive browser-based agent simulation of the SSW asset market experiment. Six agents trade a finite-lived asset across 4 rounds with experience-indexed belief updating.',
        href: '/simulator'
      },
      {
        title: 'Collective Trades',
        description: 'Real-time insider trades dashboard with network graph visualization. Track insider, institutional, and congressional stock trades across the entire market.',
        href: 'https://collective-trades.herokuapp.com'
      }
    ]} />
  </section>

  <!-- Recent Activity -->
  <section class="dash-section">
    <h2 class="section-label">ACTIVITY</h2>
    <GitHubActivity client:load />
  </section>

  <!-- Contact -->
  <section class="dash-section">
    <h2 class="section-label">CONTACT</h2>
    <div class="contact-grid">
      <a href="https://www.linkedin.com/in/leeszeray/" target="_blank" rel="noopener" class="contact-item">
        <span class="contact-arrow">→</span>
        <span class="contact-type">LinkedIn</span>
        <span class="contact-value">leeszeray</span>
      </a>
      <a href="mailto:uqslee65@uq.edu.au" class="contact-item">
        <span class="contact-arrow">→</span>
        <span class="contact-type">Email</span>
        <span class="contact-value">uqslee65@uq.edu.au</span>
      </a>
      <a href="tel:+610493713215" class="contact-item">
        <span class="contact-arrow">→</span>
        <span class="contact-type">Phone</span>
        <span class="contact-value">+61 0493713215</span>
      </a>
    </div>
  </section>

  <!-- Quick Links -->
  <section class="dash-section">
    <h2 class="section-label">EXPLORE</h2>
    <div class="quick-links">
      <a href="/research" class="quick-link">Research →</a>
      <a href="/replications" class="quick-link">Replications →</a>
      <a href="/simulator" class="quick-link">Simulator →</a>
      <a href="/about" class="quick-link">About →</a>
    </div>
  </section>
</BaseLayout>

<style>
  .dash-header h1 {
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.2em;
    color: var(--text-faint);
    text-transform: uppercase;
  }

  .dash-header p {
    font-size: 13px;
    color: var(--text-dim);
    margin-top: 0.25rem;
  }

  .dash-section {
    margin-top: 3rem;
  }

  .section-label {
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.16em;
    color: var(--text-faint);
    text-transform: uppercase;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .contact-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
    color: var(--text-dim);
    text-decoration: none;
    font-size: 13px;
    transition: color 0.15s;
  }

  .contact-item:hover {
    color: var(--text);
  }

  .contact-item:last-child {
    border-bottom: none;
  }

  .contact-arrow {
    color: var(--text-faint);
    font-size: 14px;
  }

  .contact-type {
    width: 5rem;
    color: var(--text-faint);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .contact-value {
    color: inherit;
  }

  .quick-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .quick-link {
    padding: 0.5rem 1rem;
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-decoration: none;
    transition: all 0.15s;
  }

  .quick-link:hover {
    color: var(--text);
    border-color: rgba(255, 255, 255, 0.14);
  }
</style>
