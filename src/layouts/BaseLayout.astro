---
import Nav from '../components/Nav.astro';
import { EngagementPopup } from '../components/EngagementPopup.tsx';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  fullBleed?: boolean;
}

const { title, description = 'PhD Finance Researcher — Experimental Economics, Market Microstructure, LLM Agents', fullBleed = false } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    {import.meta.env.PUBLIC_UMAMI_URL && import.meta.env.PUBLIC_UMAMI_ID && (
      <script defer src={`${import.meta.env.PUBLIC_UMAMI_URL}/script.js`} data-website-id={import.meta.env.PUBLIC_UMAMI_ID}></script>
    )}

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <Nav />
    {fullBleed ? (
      <main>
        <slot />
      </main>
    ) : (
      <main class="main-content">
        <slot />
      </main>
    )}
    <EngagementPopup client:idle />
    <footer class="site-footer">
      <div class="footer-inner">
        <span class="footer-text">&copy; {new Date().getFullYear()} Joshua Lee</span>
        <a href="https://github.com/uqslee65" target="_blank" rel="noopener">GitHub</a>
      </div>
    </footer>
  </body>
</html>

<style>
  .main-content {
    max-width: 64rem;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    min-height: calc(100vh - var(--nav-height) - 60px);
  }
  .site-footer {
    border-top: 1px solid var(--border);
    padding: 1rem 1.5rem;
  }
  .footer-inner {
    max-width: 64rem;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    font-size: 10px;
    color: var(--text-faint);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .footer-inner a {
    color: var(--text-faint);
  }
  .footer-inner a:hover {
    color: var(--text-dim);
  }
</style>
