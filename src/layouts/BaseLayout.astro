---
import Nav from '../components/Nav.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'PhD Finance Researcher — Experimental Economics, Market Microstructure, LLM Agents' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <Nav />
    <main class="main-content">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-inner">
        <span class="footer-text">&copy; {new Date().getFullYear()} Josh</span>
        <a href="https://github.com/lszeray" target="_blank" rel="noopener">GitHub</a>
      </div>
    </footer>
  </body>
</html>

<style>
  .main-content {
    max-width: 64rem;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    min-height: calc(100vh - var(--nav-height) - 60px);
  }
  .site-footer {
    border-top: 1px solid var(--border);
    padding: 1rem 1.5rem;
  }
  .footer-inner {
    max-width: 64rem;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    font-size: 0.8rem;
    color: var(--fg-3);
  }
</style>
