---
interface Props {
  title: string;
  date: string;
  excerpt: string;
  slug: string;
  tags?: string[];
}
const { title, date, excerpt, slug, tags = [] } = Astro.props;
---

<a href={`/blog/${slug}`} class="card blog-card">
  <time class="blog-date">{new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
  <h3 class="blog-title">{title}</h3>
  <p class="blog-excerpt">{excerpt}</p>
  {tags.length > 0 && (
    <div class="blog-tags">
      {tags.map(t => <span class="tag">{t}</span>)}
    </div>
  )}
</a>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    color: inherit;
  }
  .blog-date {
    font-size: 0.75rem;
    color: var(--text-faint);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .blog-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
  }
  .blog-card:hover .blog-title {
    color: var(--text);
  }
  .blog-excerpt {
    font-size: 0.85rem;
    color: var(--text-dim);
    line-height: 1.5;
  }
  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: auto;
  }
</style>
