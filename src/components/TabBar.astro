---
interface Props {
  tabs: string[];
  activeTab?: string;
  id?: string;
}
const { tabs, activeTab = tabs[0], id = 'tabbar' } = Astro.props;
---

<div class="nav-tabs" id={id} role="tablist">
  {tabs.map(tab => (
    <button
      class:list={['nav-tab', { active: tab === activeTab }]}
      role="tab"
      aria-selected={tab === activeTab ? 'true' : 'false'}
      data-tab={tab}
    >
      {tab}
    </button>
  ))}
</div>

<script>
  document.querySelectorAll('.nav-tabs').forEach(bar => {
    const buttons = bar.querySelectorAll('.nav-tab');
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        buttons.forEach(b => {
          b.classList.remove('active');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-selected', 'true');

        const tabName = (btn as HTMLElement).dataset.tab;
        document.querySelectorAll('[data-tab-content]').forEach(panel => {
          const el = panel as HTMLElement;
          el.style.display = el.dataset.tabContent === tabName ? '' : 'none';
        });
      });
    });
  });
</script>
