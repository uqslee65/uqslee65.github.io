---
import GitHubActivity from './GitHubActivity.tsx';

interface Props {
  activityData?: number[][] | null;
}
const { activityData } = Astro.props;
---

<section class="hero">
  <div class="hero-bg">
    <GitHubActivity client:load data={activityData} />
  </div>

  <div class="hero-split">
    <div class="hero-left">
      <h1 class="hero-name">
        JOSHUA<br />
        <span class="hero-name-dim">LEE</span>
      </h1>
    </div>

    <div class="hero-right">
      <div class="hero-chips">
        <span class="chip">Finance PhD Student</span>
        <span class="chip-at">@</span>
        <span class="chip">University of Queensland</span>
      </div>
      <p class="hero-desc">
        Building an open-source archive of replication studies in empirical finance —
        reproducible code, documented methodology, and growing coverage of canonical papers.
        A <em>tidyfinance</em> alternative for empirical methods in finance and economics,
        built by a PhD student, for PhD students.
      </p>
      <div class="hero-cta-row">
        <a href="#work" class="hero-cta hero-cta-primary">VIEW WORK</a>
        <a href="/about" class="hero-cta hero-cta-secondary">ABOUT ME</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 4rem 1.5rem;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    opacity: 0.12;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    overflow: hidden;
  }

  .hero-split {
    position: relative;
    z-index: 10;
    max-width: 64rem;
    width: 100%;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-name {
    font-size: clamp(42px, 7vw, 72px);
    font-weight: 300;
    letter-spacing: -0.02em;
    color: rgba(255, 255, 255, 0.92);
    line-height: 1.0;
    margin: 0;
    white-space: nowrap;
  }

  .hero-name-dim {
    color: rgba(255, 255, 255, 0.28);
  }

  .hero-right {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .hero-chips {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .chip {
    font-size: 10px;
    padding: 0.3rem 0.7rem;
    border: 1px solid var(--border);
    background: var(--bg-surface);
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .chip-at {
    font-size: 11px;
    color: var(--text-faint);
  }

  .hero-desc {
    font-size: 13px;
    color: var(--text-dim);
    line-height: 1.7;
    max-width: 28rem;
  }

  .hero-desc em {
    color: var(--text);
    font-style: normal;
  }

  .hero-cta-row {
    display: flex;
    gap: 0.75rem;
  }

  .hero-cta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    padding: 10px 24px;
    text-transform: uppercase;
    text-decoration: none;
    background: transparent;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }

  .hero-cta-primary {
    border: 1px solid rgba(255, 255, 255, 0.45);
    color: rgba(255, 255, 255, 0.9);
  }
  .hero-cta-primary:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.75);
  }

  .hero-cta-secondary {
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.4);
  }
  .hero-cta-secondary:hover {
    border-color: rgba(255, 255, 255, 0.3);
    color: rgba(255, 255, 255, 0.7);
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding: 3rem 1.5rem;
    }
    .hero-split {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .hero-name {
      font-size: 42px;
    }
  }

  @media (max-width: 480px) {
    .hero-cta-row {
      flex-direction: column;
    }
    .hero-cta {
      width: 100%;
      text-align: center;
    }
  }
</style>
