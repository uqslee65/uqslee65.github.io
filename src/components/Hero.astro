---
interface Props {
  name: string;
  title: string;
  tagline: string;
}
const { name, title, tagline } = Astro.props;
---

<section class="hero fade-in">
  <h1 class="hero-name">{name}</h1>
  <p class="hero-title">{title}</p>
  <p class="hero-tagline">{tagline}</p>
</section>

<style>
  .hero {
    text-align: left;
    padding: 3rem 0 2.5rem;
  }
  .hero-name {
    font-size: 2.75rem;
    font-weight: 700;
    color: var(--fg);
    letter-spacing: -0.03em;
    line-height: 1.1;
  }
  .hero-title {
    font-size: 1rem;
    color: var(--accent);
    font-weight: 500;
    margin-top: 0.75rem;
  }
  .hero-tagline {
    font-size: 0.9rem;
    color: var(--fg-2);
    margin-top: 0.5rem;
    max-width: 32rem;
    line-height: 1.5;
  }
  @media (max-width: 640px) {
    .hero-name { font-size: 2rem; }
  }
</style>
