---
interface Props {
  name: string;
  title: string;
  tagline: string;
}
const { name, title, tagline } = Astro.props;
---

<section class="hero fade-in">
  <h1 class="hero-name">{name}</h1>
  <p class="hero-title">{title}</p>
  <p class="hero-tagline">{tagline}</p>
</section>

<style>
  .hero {
    text-align: left;
    padding: 4rem 0 3rem;
  }
  .hero-name {
    font-size: 3.5rem;
    font-weight: 700;
    color: var(--fg);
    letter-spacing: -0.03em;
    line-height: 1.0;
    border-left: 4px solid var(--accent);
    padding-left: 1rem;
  }
  .hero-title {
    font-size: 1rem;
    color: var(--accent);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 1rem;
  }
  .hero-tagline {
    font-size: 0.875rem;
    color: var(--fg-2);
    margin-top: 0.75rem;
    max-width: 32rem;
  }
</style>
