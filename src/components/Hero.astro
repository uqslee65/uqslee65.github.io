---
interface Props {
  activityData?: number[][] | null;
}
---

<section class="hero">
  <div class="hero-split">
    <div class="hero-left">
      <h1 class="hero-name">
        JOSHUA<br />
        <span class="hero-name-dim">LEE</span>
      </h1>
      <p class="hero-role">Finance PhD Student <span class="hero-role-at">@</span><br />University of Queensland</p>
    </div>

    <div class="hero-right">
    
    <p class="hero-desc">
      Documenting my PhD journey through research, replications, and code. This portfolio
      brings together my work in empirical finance and economics, paper reading notes,
      open-source projects, and the tools I’m building along the way.
    </p>
      <div class="hero-cta-row">
        <a href="/work" class="hero-cta hero-cta-primary">VIEW WORK</a>
        <a href="/about" class="hero-cta hero-cta-secondary">ABOUT ME</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: calc(100vh - var(--nav-height));
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 2rem 1.5rem;
  }

.hero-split {
    position: relative;
    z-index: 10;
    max-width: 64rem;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: center;
    margin: 0 auto;
  }

  .hero-left {
    text-align: right;
  }

  .hero-name {
    font-size: clamp(42px, 7vw, 72px);
    font-weight: 300;
    letter-spacing: -0.02em;
    color: var(--text);
    line-height: 1.0;
    margin: 0;
    white-space: nowrap;
  }

  .hero-name-dim {
    color: var(--text-faint);
  }

  .hero-role {
    font-size: 10px;
    color: var(--text-faint);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-top: 0.75rem;
    white-space: nowrap;
  }

  .hero-role-at {
    color: var(--text-faint);
    margin: 0 0.2em;
  }

  .hero-right {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

.hero-desc {
    font-size: 13px;
    color: var(--text-dim);
    line-height: 1.7;
    max-width: 28rem;
  }

  .hero-desc em {
    color: var(--text);
    font-style: normal;
  }

  .hero-cta-row {
    display: flex;
    gap: 0.75rem;
  }

  .hero-cta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    padding: 10px 24px;
    text-transform: uppercase;
    text-decoration: none;
    background: transparent;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }

  .hero-cta-primary {
    border: 1px solid var(--border-mid);
    color: var(--text);
  }
  .hero-cta-primary:hover {
    background: var(--bg-surface);
    border-color: var(--text-dim);
  }

  .hero-cta-secondary {
    border: 1px solid var(--border);
    color: var(--text-dim);
  }
  .hero-cta-secondary:hover {
    border-color: var(--border-mid);
    color: var(--text);
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding: 3rem 1.5rem;
    }
    .hero-split {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .hero-name {
      font-size: 42px;
    }
    .hero-role {
      white-space: normal;
      text-align: left;
    }
    .hero-left {
      text-align: left;
    }
  }

  @media (max-width: 480px) {
    .hero-cta-row {
      flex-direction: column;
    }
    .hero-cta {
      width: 100%;
      text-align: center;
    }
  }
</style>
