---
import { fetchRepoStats } from '../lib/github';

interface Props {
  owner: string;
  repo: string;
  description?: string;
}

const { owner, repo, description } = Astro.props;
const stats = await fetchRepoStats(owner, repo);
---

{stats ? (
  <div class="repo-stats">
    <a
      href={`https://github.com/${owner}/${repo}`}
      target="_blank"
      rel="noopener noreferrer"
      class="repo-link"
    >
      <span class="repo-name">{owner}/{repo}</span>
    </a>
    {(description ?? stats.description) && (
      <p class="repo-desc">{description ?? stats.description}</p>
    )}
    <div class="repo-meta">
      {stats.stars > 0 && (
        <span class="meta-item" title="Stars">
          <span aria-hidden="true">★</span>
          {stats.stars.toLocaleString()}
        </span>
      )}
      {stats.forks > 0 && (
        <span class="meta-item" title="Forks">
          <span aria-hidden="true">⑂</span>
          {stats.forks.toLocaleString()}
        </span>
      )}
      {stats.language && (
        <span class="meta-item" title="Language">
          <span aria-hidden="true" class="lang-dot">●</span>
          {stats.language}
        </span>
      )}
    </div>
  </div>
) : (
  <div class="repo-stats repo-stats--fallback">
    <a
      href={`https://github.com/${owner}/${repo}`}
      target="_blank"
      rel="noopener noreferrer"
      class="repo-link"
    >
      <span class="repo-name">{owner}/{repo}</span>
    </a>
    {description && <p class="repo-desc">{description}</p>}
    <span class="meta-unavailable">Stats unavailable</span>
  </div>
)}

<style>
  .repo-stats {
    display: inline-flex;
    flex-direction: column;
    gap: 0.35rem;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    padding: 0.75rem 1rem;
    max-width: 100%;
  }

  .repo-link {
    text-decoration: none;
  }
  .repo-link:hover .repo-name {
    color: var(--text-dim);
  }

  .repo-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    transition: color 0.15s;
  }

  .repo-desc {
    font-size: 0.78rem;
    color: var(--text-dim);
    line-height: 1.4;
    margin: 0;
  }

  .repo-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.75rem;
    color: var(--text-dim);
    font-weight: 500;
  }

  .lang-dot {
    color: var(--text);
    font-size: 0.65rem;
  }

  .meta-unavailable {
    font-size: 0.72rem;
    color: var(--text-faint);
    font-style: italic;
  }
</style>
