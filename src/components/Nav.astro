---
const { pathname } = Astro.url;
const links = [
  { href: '/', label: 'Dashboard' },
  { href: '/research', label: 'Research' },
];
---

<nav class="site-nav">
  <div class="nav-inner">
    <a href="/" class="nav-brand">J</a>
    <div class="nav-links">
      {links.map(link => (
        <a
          href={link.href}
          class:list={['nav-link', { active: pathname === link.href || (link.href !== '/' && pathname.startsWith(link.href)) }]}
        >
          {link.label}
        </a>
      ))}
    </div>
    <div class="nav-right">
      <a href="/#connect" class="connect-btn">Connect</a>
      <button id="theme-toggle" class="theme-btn" title="Toggle theme" aria-label="Toggle theme">◑</button>
    </div>
  </div>
</nav>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    height: var(--nav-height);
  }
  .nav-inner {
    max-width: 64rem;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    height: 100%;
    gap: 2rem;
  }
  .nav-brand {
    font-size: 1.25rem;
    font-weight: 700;
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    background: var(--accent);
    color: white;
  }
  .nav-links {
    display: flex;
    gap: 0;
  }
  .nav-link {
    padding: 0 1rem;
    height: var(--nav-height);
    display: flex;
    align-items: center;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--fg-2);
    border-bottom: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }
  .nav-link:hover { color: var(--fg); }
  .nav-link.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  .nav-right {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .connect-btn {
    padding: 0.4rem 0.9rem;
    font-size: 0.8rem;
    font-weight: 600;
    border-radius: 6px;
    background: var(--accent);
    color: white;
    transition: background 0.15s;
  }
  .connect-btn:hover {
    background: var(--accent-hover);
    color: white;
  }
  .theme-btn {
    background: none;
    border: 1px solid var(--border);
    border-radius: 6px;
    width: 2rem;
    height: 2rem;
    font-size: 1rem;
    cursor: pointer;
    color: var(--fg-2);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s, border-color 0.15s;
  }
  .theme-btn:hover {
    color: var(--fg);
    border-color: var(--fg-3);
  }
</style>

<script>
  const btn = document.getElementById('theme-toggle');
  const states = ['auto', 'light', 'dark'] as const;
  let idx = states.indexOf((localStorage.getItem('theme') as typeof states[number]) || 'auto');

  function apply() {
    const theme = states[idx];
    localStorage.setItem('theme', theme);
    if (theme === 'auto') {
      document.documentElement.removeAttribute('data-theme');
    } else {
      document.documentElement.setAttribute('data-theme', theme);
    }
    if (btn) btn.textContent = theme === 'dark' ? '☀' : theme === 'light' ? '☾' : '◑';
  }

  apply();
  btn?.addEventListener('click', () => { idx = (idx + 1) % 3; apply(); });
</script>
